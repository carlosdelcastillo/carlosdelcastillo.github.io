# -----------------------------------------------------------------------------
# TERMINAL / DEPENDENCIES
# -----------------------------------------------------------------------------
node_modules/
# Enforce NPM usage (ignore other lockfiles to prevent conflicts)
yarn.lock
pnpm-lock.yaml
bun.lockb
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# BUILD OUTPUTS
# -----------------------------------------------------------------------------
dist/
build/
out/
.astro/
.vercel/
.netlify/
.turbo/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# ENVIRONMENT & SECURITY (Keep these secret!)
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.env.bak

# Security keys and certificates (Safety net)
*.pem
*.pub
*.key
*.jks
*.p12
*.cer

# -----------------------------------------------------------------------------
# LOGS & DEBUGGING
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# TESTING & COVERAGE
# -----------------------------------------------------------------------------
coverage/
*.lcov
.nyc_output
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
.junit.xml

# Sonar scanner local workspace
.scannerwork/

# -----------------------------------------------------------------------------
# IDE / EDITOR / OS FILES
# -----------------------------------------------------------------------------
# VS Code
.vscode/*
*.code-workspace

# JetBrains
.idea/
*.iml

# OS Metadata
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
[Dd]esktop.ini

# -----------------------------------------------------------------------------
# CACHE & TEMPORARY FILES
# -----------------------------------------------------------------------------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.prettiercache
tmp/
temp/
pids/
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# LOCAL / PERSONAL OVERRIDES
# -----------------------------------------------------------------------------
# Any file ending in .local (e.g., TODO.local.md, notes.local.txt)
*.local
