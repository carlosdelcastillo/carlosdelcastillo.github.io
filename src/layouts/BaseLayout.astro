---
export interface Props {
  title: string;
  description: string;
  lang?: string;
}

const { title, description, lang = 'en' } = Astro.props;
const siteUrl = Astro.site
  ? new URL(Astro.site)
  : new URL('https://carlosdelcastillo.dev');
const stripLocalePrefix = (path: string) =>
  path.replace(/^\/(en|es)(\/|$)/, '/');
const requestedPath = Astro.url.pathname;
const effectivePath = requestedPath === '/' ? '/en/' : requestedPath;
const unlocalizedPath = stripLocalePrefix(effectivePath) || '/';
const localizedPath = (locale: 'en' | 'es') =>
  `/${locale}${unlocalizedPath === '/' ? '/' : unlocalizedPath}`;
const canonicalUrl = new URL(effectivePath, siteUrl).href;
const alternateEnUrl = new URL(localizedPath('en'), siteUrl).href;
const alternateEsUrl = new URL(localizedPath('es'), siteUrl).href;
const ogLocale = lang === 'es' ? 'es_ES' : 'en_US';
import '@fontsource/inter';
---

